{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=CRMSystemDb;Trusted_Connection=True;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Key": "REPLACE_WITH_YOUR_OWN_SECRET_KEY_MIN_32_CHARS",
    "Issuer": "CRMSystem.API",
    "Audience": "CRMSystem.Client",
    "ExpiryMinutes": 60
  }
}